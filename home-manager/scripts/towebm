#!/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: towebm [-q low] <input-file> [extra ffmpeg args...]"
  exit 1
}

quality=""
args=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -q|--quality)
      quality="$2"
      shift 2
      ;;
    -h|--help)
      usage
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

[[ ${#args[@]} -lt 1 ]] && usage

input="${args[0]}"
extra_args=("${args[@]:1}")
output="${input%.*}.webm"

if [[ "$quality" == "low" ]]; then
  # Get original bitrate, default to 2M if probe fails
  orig_bitrate=$(ffprobe -v error -select_streams v:0 \
    -show_entries stream=bit_rate -of csv=p=0 "$input" 2>/dev/null || echo "")
  if [[ -n "$orig_bitrate" && "$orig_bitrate" != "N/A" ]]; then
    target_bitrate=$(( orig_bitrate * 70 / 100 ))
  else
    target_bitrate=1400000
  fi

  exec ffmpeg -i "$input" \
    -vf "scale=iw/2:ih/2" \
    -b:v "${target_bitrate}" \
    "${extra_args[@]}" \
    "$output"
else
  exec ffmpeg -i "$input" "${extra_args[@]}" "$output"
fi
